# Copy this file to .env and fill in your credentials before running the backend.

# Groq API key for AI-powered SQL generation
GROQ_API_KEY=your_groq_api_key_here

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=your_supabase_url_here

# Supabase service-role or anon key
SUPABASE_KEY=your_supabase_key_here
